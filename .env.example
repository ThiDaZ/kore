NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Generate a secure random string for this (e.g., using `openssl rand -base64 32`)
BETTER_AUTH_SECRET=

# This is required so Google/Facebook know where to redirect back to (e.g., http://localhost:3000)
BETTER_AUTH_URL=

DATABASE_URL=""

# Social Providers (You get these from Google Cloud Console & Facebook Developer Portal)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

FACEBOOK_CLIENT_ID=your_facebook_client_id
FACEBOOK_CLIENT_SECRET=your_facebook_client_secret